class Solution {
public:
    bool isPalindrome(string s) {

        int start =0;
        int end = s.size()-1;
        while(start<end){
            // skip non-alphanumeric from left
            if (!isalnum(s[start])) {
                start++;
            }

            // skip non-alphanumeric from right
            else if(!isalnum(s[end])){
                end--;
            }
           else if(tolower (s[start])!=tolower (s[end])){
            return false;
           }
           else{
            start++;
            end--;
           }
        

        }
        return true;
    }
};
