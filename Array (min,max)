#include <iostream>
using namespace std;
int main(){
    int arr[] = {5,9,75,13,2,58};
    // min and max in an array
    int min = arr[0], max = arr[0];
    for(int i=1; i<5; i++){
        if(arr[i]<min){
            min = arr[i];
        }
        if(arr[i]>max){
            max = arr[i];
        }
    }
    cout<<"Minimum element: "<<min<<endl;
    cout<<"Maximum element: "<<max<<endl;


}
